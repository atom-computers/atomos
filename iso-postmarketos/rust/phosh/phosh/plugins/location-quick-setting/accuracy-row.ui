<?xml version="1.0" encoding="utf-8"?>
<interface>
  <requires lib="gtk+" version="3.24"/>
  <requires lib="libhandy" version="1.8"/>
  <template class="PhoshAccuracyRow" parent="HdyActionRow">
    <property name="visible">1</property>
    <property name="activatable">1</property>
    <child>
      <object class="GtkRevealer" id="revealer">
        <property name="visible">1</property>
        <property name="transition-type">crossfade</property>
        <property name="reveal-child" bind-source="PhoshAccuracyRow" bind-property="selected" bind-flags="default|sync-create"/>
        <child>
          <object class="GtkImage">
            <property name="visible">1</property>
            <property name="pixel-size">16</property>
            <property name="icon-name">object-select</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
