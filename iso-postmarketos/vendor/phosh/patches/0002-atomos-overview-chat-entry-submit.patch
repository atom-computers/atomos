diff --git a/src/app-grid.c b/src/app-grid.c
--- a/src/app-grid.c
+++ b/src/app-grid.c
@@ -600,28 +600,26 @@ static void
 on_search_activated (GtkSearchEntry *entry,
                      PhoshAppGrid   *self)
 {
-  PhoshAppGridPrivate *priv = phosh_app_grid_get_instance_private (self);
-  GtkFlowBoxChild *child;
+  const char *text;
+  g_autoptr (GError) err = NULL;
+  g_autofree char *arg = NULL;
+  char *argv[3];
 
-  if (!gtk_widget_has_focus (GTK_WIDGET (entry)))
-    return;
+  (void) self;
 
-  /* Don't activate when there isn't an active search */
-  if (!priv->search_string || *priv->search_string == '\0')
+  text = gtk_entry_get_text (GTK_ENTRY (entry));
+  if (text == NULL || *text == '\0')
     return;
 
-  child = gtk_flow_box_get_child_at_index (GTK_FLOW_BOX (priv->apps), 0);
+  arg = g_strdup (text);
+  argv[0] = (char *) "/usr/libexec/atomos-overview-chat-submit";
+  argv[1] = arg;
+  argv[2] = NULL;
 
-  /* No results */
-  if (child == NULL)
-    return;
+  if (!g_spawn_async (NULL, argv, NULL, G_SPAWN_SEARCH_PATH, NULL, NULL, NULL, &err))
+    g_warning ("atomos-overview-chat: %s", err->message);
 
-  if (G_LIKELY (PHOSH_IS_APP_GRID_BUTTON (child))) {
-    gtk_widget_activate (GTK_WIDGET (child));
-  } else {
-    g_critical ("Unexpected child type, %s",
-                g_type_name (G_TYPE_FROM_INSTANCE (child)));
-  }
+  gtk_entry_set_text (GTK_ENTRY (entry), "");
 }
 
 
