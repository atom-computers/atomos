# shellcheck shell=bash

PROFILE_NAME="arm64-virt"
PMB_WORK=".pmbootstrap/arm64-virt"

# ARM64 QEMU device package (required by `pmbootstrap qemu`).
PMOS_DEVICE="qemu-aarch64"
PMOS_UI="phosh"
PMOS_CHANNEL="edge"
# simdutf: vte3-gtk4 needs so:libsimdutf.so.31 on edge
# squeekboard: on-screen keyboard (ensures dismiss behavior is available in Phosh app search)
PMOS_EXTRA_PACKAGES="networkmanager,pipewire,wireplumber,dconf,dbus,squeekboard,simdutf"
PMOS_LOCK_PARITY="1"
# Opportunistic additions; missing packages are skipped.
PMOS_PARITY_PACKAGE_CANDIDATES="phosh-mobile-settings,squeekboard,feedbackd"
PMOS_INSTALL_PASSWORD="147147"

# --- Phosh / custom APK (docs/PHOSH.md) ---
# PMOS_CLEAR_PHOSH_FAVOURITES="1"
# PMOS_CUSTOM_APK_REPO_URLS=""
# PMOS_CUSTOM_APK_KEY_FILES=""
# PMOS_CUSTOM_APK_PACKAGES=""

# QEMU defaults tuned for Apple Silicon iteration.
PMOS_QEMU_MEMORY_MB="4096"
PMOS_QEMU_IMAGE_SIZE="8G"
