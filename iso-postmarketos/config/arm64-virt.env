# shellcheck shell=bash

PROFILE_NAME="arm64-virt"
PMB_WORK=".pmbootstrap/arm64-virt"

# ARM64 QEMU device package (required by `pmbootstrap qemu`).
PMOS_DEVICE="qemu-aarch64"
PMOS_UI="phosh"
PMOS_CHANNEL="edge"
# Optional reproducibility pin: set exact pmaports git commit hash.
# PMOS_PMAPORTS_COMMIT="0123456789abcdef0123456789abcdef01234567"
# openssh-server: required for SSH; `scripts/qemu/run-local-qemu.sh` forwards host 127.0.0.1:2222 -> guest :22 (user netdev). Hardware USB images use 172.16.42.1 instead — that subnet is USB gadget/NCM, not QEMU virtio-net.
# simdutf: vte3-gtk4 needs so:libsimdutf.so.31 on edge
# squeekboard: on-screen keyboard (ensures dismiss behavior is available in Phosh app search)
# rust/cargo/build-base + *-dev libs: allow native on-device rebuild/debug of atomos-overview-chat-ui.
PMOS_EXTRA_PACKAGES="networkmanager,pipewire,pipewire-pulse,wireplumber,dconf,dbus,openssh-server,squeekboard,simdutf,build-base,binutils,gdb,cargo,rust,pkgconf,glib-dev,gdk-pixbuf-dev,pango-dev,cairo-dev,gtk4.0-dev,libadwaita-dev,gtk4-layer-shell-dev,ripgrep"
PMOS_LOCK_PARITY="1"
# Phosh lock timing: disable idle-triggered lock (indefinite) on arm64-virt.
PMOS_SCREENLOCK_IDLE_SECONDS="0"
PMOS_SCREENLOCK_LOCK_DELAY_SECONDS="0"
# Opportunistic additions; missing packages are skipped.
PMOS_PARITY_PACKAGE_CANDIDATES="phosh-mobile-settings,squeekboard,feedbackd"
PMOS_INSTALL_ATOMOS_AGENTS="1"
PMOS_INSTALL_PASSWORD="147147"

# --- Phosh / custom APK (docs/PHOSH.md) ---
# PMOS_CLEAR_PHOSH_FAVOURITES="1"
# PMOS_CUSTOM_APK_REPO_URLS=""
# PMOS_CUSTOM_APK_KEY_FILES=""
# PMOS_CUSTOM_APK_PACKAGES=""

# QEMU defaults tuned for Apple Silicon iteration.
PMOS_QEMU_MEMORY_MB="4096"
PMOS_QEMU_IMAGE_SIZE="8G"
