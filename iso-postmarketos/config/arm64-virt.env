# shellcheck shell=bash

PROFILE_NAME="arm64-virt"
PMB_WORK=".pmbootstrap/arm64-virt"

# ARM64 QEMU device package (required by `pmbootstrap qemu`).
PMOS_DEVICE="qemu-aarch64"
PMOS_UI="phosh"
PMOS_CHANNEL="edge"
# Optional reproducibility pin: set exact pmaports git commit hash.
# PMOS_PMAPORTS_COMMIT="0123456789abcdef0123456789abcdef01234567"
# openssh-server: required for SSH; `scripts/qemu/run-local-qemu.sh` forwards host 127.0.0.1:2222 -> guest :22 (user netdev). Hardware USB images use 172.16.42.1 instead — that subnet is USB gadget/NCM, not QEMU virtio-net.
# simdutf: vte3-gtk4 needs so:libsimdutf.so.31 on edge
# stevia: Phosh OSK (build-qemu maps pmaports default_osk to stevia, not squeekboard).
# rust/cargo/build-base + *-dev libs: allow native on-device rebuild/debug of atomos-overview-chat-ui.
PMOS_EXTRA_PACKAGES="networkmanager,pipewire,pipewire-pulse,wireplumber,dconf,dbus,openssh-server-pam,stevia,simdutf,build-base,binutils,gdb,cargo,rust,pkgconf,glib-dev,gdk-pixbuf-dev,pango-dev,cairo-dev,gtk4.0-dev,libadwaita-dev,gtk4-layer-shell-dev,ripgrep"

# Phosh hotfix: scripts/phosh/hotfix-phosh.sh installs to /usr/libexec/phosh
# (ATOMOS_PHOSH_REMOTE_PREFIX defaults to /usr). Do not use /usr/local unless
# greetd is reconfigured to launch that binary.
#
# Phosh on-device build deps (consumed by scripts/phosh/hotfix-phosh.sh).
# Mirrors the apk stanza in scripts/build-qemu.sh's container build so the
# hotfix's `meson setup` resolves the same package set the cached host build
# does. Keep in sync with PHOSH_BUILD_DEPS in scripts/phosh/hotfix-phosh.sh
# and with config/fairphone-fp4.env.
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,meson,ninja-build"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,gtk+3.0-dev,libhandy1-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,gnome-bluetooth-dev,gnome-desktop-dev,libgudev-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,evolution-data-server-dev,gcr-dev,libsecret-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,callaudiod-dev,feedbackd-dev,pulseaudio-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,networkmanager-dev,modemmanager-dev,upower-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,evince-dev,qrcodegen-dev,polkit-dev,elogind-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,gobject-introspection-dev,vala"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,wayland-dev,wayland-protocols,libxkbcommon-dev,dbus-dev,linux-pam-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,libsoup3-dev,json-glib-dev"
PMOS_EXTRA_PACKAGES="$PMOS_EXTRA_PACKAGES,appstream-dev,fribidi-dev,desktop-file-utils,gstreamer-dev"
# Session user UID (postmarketOS default; build-qemu).
PMOS_USER_UID="10000"
PMOS_LOCK_PARITY="1"
# Phosh lock timing: lock after 5m idle, immediately once the screen blanks.
PMOS_SCREENLOCK_IDLE_SECONDS="300"
PMOS_SCREENLOCK_LOCK_DELAY_SECONDS="0"
# Opportunistic additions; missing packages are skipped.
PMOS_PARITY_PACKAGE_CANDIDATES="phosh-mobile-settings,feedbackd"
PMOS_INSTALL_ATOMOS_AGENTS="1"
PMOS_INSTALL_PASSWORD="147147"

# --- Phosh / custom APK (docs/PHOSH.md) ---
# PMOS_CLEAR_PHOSH_FAVOURITES="1"
# PMOS_CUSTOM_APK_REPO_URLS=""
# PMOS_CUSTOM_APK_KEY_FILES=""
# PMOS_CUSTOM_APK_PACKAGES=""

# QEMU defaults tuned for Apple Silicon iteration.
PMOS_QEMU_MEMORY_MB="4096"
PMOS_QEMU_IMAGE_SIZE="8G"

# Rust app-switcher defaults (on for make build-qemu / make build images).
# Replaces the legacy ATOMOS_SWIPE_BRIDGE_* knobs — the rust app-switcher
# folded in the bottom-edge swipe gesture and now owns both surfaces.
ATOMOS_APP_HANDLER_ENABLE_RUNTIME_DEFAULT="1"
ATOMOS_APP_HANDLER_TARGET_TRIPLE="aarch64-unknown-linux-musl"

# Overview chat UI runtime gate: /usr/libexec/atomos-overview-chat-ui --show
# is a no-op unless ATOMOS_OVERVIEW_CHAT_UI_ENABLE_RUNTIME=1. The launcher
# inlines this value at install-overview-chat-ui.sh time.
ATOMOS_OVERVIEW_CHAT_UI_ENABLE_RUNTIME_DEFAULT="1"
# QEMU/dev images: re-enable decorative CSS + dark/light theme classes in the
# rust overlay (hardware FP4 builds keep install defaults of 1 = disabled).
ATOMOS_OVERVIEW_CHAT_UI_DISABLE_CUSTOM_CSS_DEFAULT="0"
ATOMOS_OVERVIEW_CHAT_UI_DISABLE_THEME_CLASS_DEFAULT="0"

# Greetd auto-login (dev/integration test image only). Set to 1 here so that
# tests/integration/test_qemu_phosh_login_lifetime.py can drive past the lock
# screen without typing into the QEMU display. Production images for hardware
# (config/fairphone-fp4.env) leave this unset so Phrog remains the greeter.
# Override at the build boundary with ATOMOS_AUTOLOGIN=0 to fall back to Phrog
# on the QEMU image (e.g. when testing the Phrog greeter itself).
PMOS_AUTOLOGIN="1"

# Developer / Debug mode: allow SSH (ports 22, 2222) through the firewall
ATOMOS_DEVELOPER_MODE="1"
ATOMOS_DEBUG_FIREWALL="1"

