# shellcheck shell=bash

PROFILE_NAME="fairphone-fp4"
PMB_WORK=".pmbootstrap/fairphone-fp4"

# postmarketOS target selection
PMOS_DEVICE="fairphone-fp4"
PMOS_UI="phosh"

# Keep edge by default for freshest packaging.
PMOS_CHANNEL="edge"

# Extra packages to pull into the target rootfs.
# openssh-server: sshd for USB / LAN access
# postmarketos-usb-moded: USB gadget mode switching (systemd)
# postmarketos-usb-moded-default-profile-developer: default USB mode = developer (USB Ethernet/NCM) so ssh works over USB-C without Wi‑Fi
# squeekboard: on-screen keyboard
# simdutf: satisfies vte3-gtk4 -> so:libsimdutf.so.31 on edge (apk solver may not pull it early)
PMOS_EXTRA_PACKAGES="networkmanager,pipewire,wireplumber,dconf,dbus,openssh-server,postmarketos-usb-moded,postmarketos-usb-moded-default-profile-developer,squeekboard,simdutf"
PMOS_LOCK_PARITY="1"
# Opportunistic additions; missing packages are skipped.
PMOS_PARITY_PACKAGE_CANDIDATES="phosh-mobile-settings,feedbackd"

# Installer defaults
PMOS_INSTALL_PASSWORD="147147"

# --- Phosh / custom APK (docs/PHOSH.md) ---
# Clear home favorites strip via dconf (default on). Set 0 to keep pmaports defaults.
# PMOS_CLEAR_PHOSH_FAVOURITES="1"
# Optional: custom repository + keys + packages (wire-custom-apk-repos.sh).
# PMOS_CUSTOM_APK_REPO_URLS="https://example.invalid/custom/@edge/community"
# PMOS_CUSTOM_APK_KEY_FILES="vendor/phosh/keys/your-repo.rsa.pub"
# PMOS_CUSTOM_APK_PACKAGES="phosh"
