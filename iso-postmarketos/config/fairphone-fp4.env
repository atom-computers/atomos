# shellcheck shell=bash

PROFILE_NAME="fairphone-fp4"
PMB_WORK=".pmbootstrap/fairphone-fp4"

# postmarketOS target selection
PMOS_DEVICE="fairphone-fp4"
PMOS_UI="phosh"

# Keep edge by default for freshest packaging.
PMOS_CHANNEL="edge"
# Optional reproducibility pin: set exact pmaports git commit hash.
# PMOS_PMAPORTS_COMMIT="0123456789abcdef0123456789abcdef01234567"

# Extra packages to pull into the target rootfs.
# openssh-server: sshd for USB / LAN access
# postmarketos-usb-moded: USB gadget mode switching (systemd)
# postmarketos-usb-moded-default-profile-developer: default USB mode = developer (USB Ethernet/NCM) so ssh works over USB-C without Wi‑Fi
# squeekboard: on-screen keyboard
# simdutf: satisfies vte3-gtk4 -> so:libsimdutf.so.31 on edge (apk solver may not pull it early)
# rust/cargo/build-base + *-dev libs: allow native on-device rebuild/debug of atomos-overview-chat-ui.
# webkit2gtk-6.0: RUNTIME for atomos-home-bg (rust/atomos-home-bg/app-gtk uses
#                 the webkit6 crate -> libwebkitgtk-6.0.so.0). build-qemu lists
#                 this in BASE_APK_PACKAGES; on the FP4 pmbootstrap path we
#                 must opt-in here because pmbootstrap install only pulls
#                 postmarketos-ui-phosh's deps. Without it, the binary lands in
#                 /usr/local/bin/atomos-home-bg but exits at session start with
#                 a missing-library error and the home-bg overlay never renders.
# gtk4-layer-shell: RUNTIME for both atomos-home-bg and atomos-overview-chat-ui.
#                 gtk4-layer-shell-dev (already in this list) pulls the runtime
#                 transitively on Alpine, but listing it explicitly here makes
#                 the runtime contract obvious and survives any future split
#                 of the -dev/runtime packages.
PMOS_EXTRA_PACKAGES="networkmanager,pipewire,pipewire-pulse,wireplumber,dconf,dbus,openssh-server-pam,postmarketos-usb-moded,postmarketos-usb-moded-default-profile-developer,squeekboard,simdutf,build-base,binutils,gdb,cargo,rust,pkgconf,glib-dev,gdk-pixbuf-dev,pango-dev,cairo-dev,gtk4.0-dev,libadwaita-dev,gtk4-layer-shell,gtk4-layer-shell-dev,webkit2gtk-6.0,ripgrep"
PMOS_LOCK_PARITY="1"
# Phosh lock timing: lock after 5m idle, immediately once the screen blanks.
PMOS_SCREENLOCK_IDLE_SECONDS="300"
PMOS_SCREENLOCK_LOCK_DELAY_SECONDS="0"
# Opportunistic additions; missing packages are skipped.
PMOS_PARITY_PACKAGE_CANDIDATES="phosh-mobile-settings,squeekboard,feedbackd"
PMOS_INSTALL_ATOMOS_AGENTS="1"

# Installer defaults
PMOS_INSTALL_PASSWORD="147147"

# Phosh hotfix: scripts/phosh/hotfix-phosh.sh installs to /usr/libexec/phosh
# (ATOMOS_PHOSH_REMOTE_PREFIX defaults to /usr). Do not use /usr/local unless
# greetd is reconfigured to launch that binary.
#
# --- Phosh / custom APK (docs/PHOSH.md) ---
# Clear home favorites strip via dconf (default on). Set 0 to keep pmaports defaults.
# PMOS_CLEAR_PHOSH_FAVOURITES="1"
# Optional: custom repository + keys + packages (wire-custom-apk-repos.sh).
# PMOS_CUSTOM_APK_REPO_URLS="https://example.invalid/custom/@edge/community"
# PMOS_CUSTOM_APK_KEY_FILES="vendor/phosh/keys/your-repo.rsa.pub"
# PMOS_CUSTOM_APK_PACKAGES="phosh"

# Rust app-switcher defaults (on for make build / make build-fairphone4 images).
# Replaces the legacy ATOMOS_SWIPE_BRIDGE_* knobs — the rust app-switcher
# folded in the bottom-edge swipe gesture and now owns both surfaces.
ATOMOS_APP_HANDLER_ENABLE_RUNTIME_DEFAULT="1"
ATOMOS_APP_HANDLER_TARGET_TRIPLE="aarch64-unknown-linux-musl"

# Overview chat UI dynamic theme class and custom CSS default enable
ATOMOS_OVERVIEW_CHAT_UI_DISABLE_CUSTOM_CSS_DEFAULT="0"
ATOMOS_OVERVIEW_CHAT_UI_DISABLE_THEME_CLASS_DEFAULT="0"

# Enable hardware-accelerated rendering for the home background (WebKit accretion disk wallpaper)
# on the Adreno 619 GPU (Fairphone 4), instead of falling back to Cairo/software rendering.
ATOMOS_HOME_BG_LIBGL_ALWAYS_SOFTWARE="0"
ATOMOS_HOME_BG_GSK_RENDERER="cairo"

# Developer / Debug mode: allow SSH (ports 22, 2222) through the firewall
ATOMOS_DEVELOPER_MODE="1"
ATOMOS_DEBUG_FIREWALL="0"

